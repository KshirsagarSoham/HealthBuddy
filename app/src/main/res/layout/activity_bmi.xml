<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER (UNCHANGED STRUCTURE) -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/backbutton"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/back_button" />

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="100dp"
                    android:src="@drawable/bmi"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMI Calculator"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check your Body Mass Index"
                android:textSize="14sp"
                android:layout_gravity="center"/>

        </LinearLayout>


        <!-- INPUT CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bmi_card"
            android:padding="20dp"
            android:layout_marginTop="10dp">

            <!-- AGE -->

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Age"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- HEIGHT -->

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Height (cm)"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- WEIGHT -->

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Weight (kg)"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>


            <!-- CALCULATE BUTTON -->

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Calculate BMI"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_calculate_button"/>

            <!-- RESET BUTTON -->

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Reset"
                android:layout_marginTop="8dp"/>

        </LinearLayout>


        <!-- RESULT CARD -->

        <LinearLayout
            android:id="@+id/resultLayout"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_bmi_card"
            android:padding="20dp">

            <ProgressBar
                android:id="@+id/bmiMeter"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="200dp"
                android:layout_height="10dp"
                android:max="40"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvBmiValue"
                android:text="22.4"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvResult"
                android:text="Normal"
                android:textSize="18sp"/>

        </LinearLayout>


        <!-- BMI CATEGORY BAR -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <!-- POINTER AREA -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="24dp">

                <ImageView
                    android:id="@+id/bmiPointer"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_bmi_pointer"
                    android:layout_gravity="start"/>

            </FrameLayout>

            <!-- BMI CATEGORY BAR -->
            <LinearLayout
                android:id="@+id/bmiBar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/barUnder"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Under"
                    android:background="#4FC3F7"/>

                <TextView
                    android:id="@+id/barNormal"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Normal"
                    android:background="#66BB6A"/>

                <TextView
                    android:id="@+id/barOver"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Over"
                    android:background="#FFA726"/>

                <TextView
                    android:id="@+id/barObese"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Obese"
                    android:background="#EF5350"/>

            </LinearLayout>

            <!-- RANGE LABELS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="&lt;18.5"
                    android:gravity="center"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="18.5-25"
                    android:gravity="center"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="25-30"
                    android:gravity="center"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="30+"
                    android:gravity="center"
                    android:textSize="12sp"/>

            </LinearLayout>

        </LinearLayout>


        <!-- HEALTH TIP -->

        <TextView
            android:id="@+id/tvHealthTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Health Tip"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_bmi_card"/>


        <!-- BMI INFO -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/tvBmiInfoTitle"
            android:text="What is BMI?"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/tvBmiInfo"
            android:visibility="gone"
            android:text="Body Mass Index (BMI) is a value derived from height and weight used to estimate body fat."
            android:layout_marginTop="6dp"/>

    </LinearLayout>
</ScrollView>