<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_health"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Health &amp; Wellness"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="32dp"
            android:gravity="center" />

        <!-- 7-Day Steps - Simple Progress Bars -->
        <LinearLayout
            android:id="@+id/weekly_steps_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_step_card"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LAST 7 DAYS STEPS"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Dynamic progress bars populated in Java -->
            <LinearLayout
                android:id="@+id/day_progress_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10sp"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Steps Progress Circle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="228dp"
            android:layout_marginBottom="40dp"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="80dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/purple_500"
                app:strokeWidth="4dp">

                <LinearLayout
                    android:layout_width="163dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_steps"
                    android:gravity="center"
                    android:orientation="vertical">

                    <!-- ✅ REPLACED Lottie with ImageView -->

                    <ImageView
                        android:layout_width="160dp"
                        android:layout_height="47dp"
                        android:layout_marginBottom="1dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/step2"
                        android:tint="@color/white" />

                    <TextView
                        android:id="@+id/tv_steps_today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8200"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_daily_goal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Goal 10,000 steps"
                        android:textColor="@color/white_80"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Secondary Progress Bar -->
            <ProgressBar
                android:id="@+id/pb_steps"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="206dp"
                android:layout_height="26dp"
                android:backgroundTint="@color/white_20"
                android:max="100"
                android:progress="82"
                android:progressTint="@color/purple_500" />

        </LinearLayout>

        <!-- Medicine Intake -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Medicine Intake Today"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_medicine_morning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Morning Pill (8:00 AM) ✓"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="@drawable/bg_medicine_taken"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_medicine_lunch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lunch Supplement (1:00 PM) ⏳"
                android:textSize="16sp"
                android:padding="16dp"
                android:background="@drawable/bg_medicine_pending" />

        </LinearLayout>

        <!-- ✅ REPLACED Lottie medicine with simple icon -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@android:drawable/stat_notify_sync"
            android:tint="#4CAF50"
            android:scaleType="centerInside" />

    </LinearLayout>
</ScrollView>