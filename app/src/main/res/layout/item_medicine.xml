<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Color band -->
        <View
            android:id="@+id/view_color_band"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="#5D96E2" />

        <!-- Card body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Name + Delete -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_med_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medicine Name"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A2E4A" />

                    <TextView
                        android:id="@+id/tv_med_dosage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="1 tablet"
                        android:textSize="12sp"
                        android:textColor="#8AAEE0" />

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_med_delete"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:tint="#C6DBF7"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Delete" />

            </LinearLayout>

            <!-- Timing chip -->
            <TextView
                android:id="@+id/tv_med_timings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="⏰ 08:00"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#5D96E2"
                android:background="@drawable/chip_timing_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="10dp"
                android:background="#EEF5FD" />

            <!-- Dose label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MARK DOSES TAKEN TODAY"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textColor="#A3C4F0"
                android:layout_marginBottom="6dp" />

            <!-- ── Dose 1 row ── -->
            <LinearLayout
                android:id="@+id/row_dose1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:weightSum="1"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/cb_dose1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:00"
                    android:textSize="13sp"
                    android:textColor="#1A2E4A"
                    android:theme="@style/CheckBoxTheme"
                    android:paddingStart="10dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tag_dose1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#5D96E2"
                    android:background="@drawable/chip_timing_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

            </LinearLayout>

            <!-- ── Dose 2 row ── -->
            <LinearLayout
                android:id="@+id/row_dose2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:weightSum="1"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginTop="4dp"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/cb_dose2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14:00"
                    android:textSize="13sp"
                    android:textColor="#1A2E4A"
                    android:theme="@style/CheckBoxTheme"
                    android:paddingStart="10dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tag_dose2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#5D96E2"
                    android:background="@drawable/chip_timing_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

            </LinearLayout>

            <!-- ── Dose 3 row ── -->
            <LinearLayout
                android:id="@+id/row_dose3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:weightSum="1"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginTop="4dp"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/cb_dose3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21:00"
                    android:textSize="13sp"
                    android:textColor="#1A2E4A"
                    android:theme="@style/CheckBoxTheme"
                    android:paddingStart="10dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tag_dose3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#5D96E2"
                    android:background="@drawable/chip_timing_bg"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

            </LinearLayout>

            <!-- Progress row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Today's progress"
                    android:textSize="11sp"
                    android:textColor="#A3C4F0" />

                <TextView
                    android:id="@+id/tv_med_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 1"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#5D96E2" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/pb_med_card"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:progressBackgroundTint="#EEF5FD"
                android:progressTint="#5D96E2"
                android:max="3"
                android:progress="0" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>